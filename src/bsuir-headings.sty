\ProvidesExplPackage {bsuir-headings} {2026-03-12} {2.9} {BSUIR headings configuration}
\RequirePackage{needspace}

\addto\captionsrussian{\renewcommand*\contentsname{Содержание}}

\ExplSyntaxOff
\makeatletter
\renewcommand{\@dotsep}{1}
\makeatother
\ExplSyntaxOn

\providecommand\phantomsection{}

\setcounter{secnumdepth}{3}
\setcounter{tocdepth}{3}

\renewcommand* \thechapter       { \arabic{chapter} }
\renewcommand* \thesection       { \thechapter.\arabic{section} }
\renewcommand* \thesubsection    { \thesection.\arabic{subsection} }
\renewcommand* \thesubsubsection { \thesubsection.\arabic{subsubsection} }

% Счётчик приложений — буква русского алфавита
\newcounter{bsuir@appendix}

\cs_new:Npn \bsuir_appendix_letter:n #1
  {
    \int_case:nn {#1}
      {
        {1}  {А} {2}  {Б} {3}  {В} {4}  {Г} {5}  {Д}
        {6}  {Е} {7}  {Ж} {8}  {З} {9}  {И} {10} {К}
        {11} {Л} {12} {М} {13} {Н} {14} {О} {15} {П}
        {16} {Р} {17} {С} {18} {Т} {19} {У} {20} {Ф}
        {21} {Х} {22} {Ц} {23} {Ч} {24} {Ш} {25} {Щ}
        {26} {Э} {27} {Ю} {28} {Я}
      }
  }

% =============================================================================
% 3. Содержание через KOMA
% =============================================================================
\ExplSyntaxOff
\setkomafont{chapterentry}           {\normalfont\normalsize}
\setkomafont{chapterentrypagenumber} {\normalfont\normalsize}
\setkomafont{chapterentrydots}       {\normalfont\normalsize}

\RedeclareSectionCommand[tocindent=0mm,  tocbeforeskip=0pt]{chapter}
\RedeclareSectionCommand[tocindent=5mm,  tocbeforeskip=0pt]{section}
\RedeclareSectionCommand[tocindent=10mm, tocbeforeskip=0pt]{subsection}
